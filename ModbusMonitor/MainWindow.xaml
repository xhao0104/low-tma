<Window x:Class="ModbusMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:ModbusMonitor.Views"
        xmlns:converters="clr-namespace:ModbusMonitor.Converters"
        xmlns:vm="clr-namespace:ModbusMonitor.ViewModels"
        Title="🏭 工业温度监控系统 - Modbus RTU Monitor"
        MinWidth="1100" MinHeight="700"
        Width="1280" Height="800"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PrimaryBgBrush}"
        Closing="Window_Closing">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <converters:ConnectionStatusColorConverter x:Key="ConnStatusColorConv"/>
        <converters:BoolToVisibilityConverter      x:Key="BoolToVisConv"/>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===== 顶部标题栏 ===== -->
        <Border Grid.Row="0" Background="{StaticResource SecondaryBgBrush}"
                BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1"
                Padding="20,12">
            <DockPanel>
                <!-- 左侧标题 -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🏭" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="工业温度监控系统" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text="Modbus RTU over TCP  ·  塔石双路透传" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- 右侧双路连接状态 -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <!-- 通道 1 状态 -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                        <TextBlock Text="COM1:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Ch1StatusText}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding Ch1Connected, Converter={StaticResource ConnStatusColorConv}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- 通道 2 状态 -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="COM2:" FontSize="11" Foreground="{StaticResource TextMutedBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding Ch2StatusText}" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{Binding Ch2Connected, Converter={StaticResource ConnStatusColorConv}}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ===== 主内容区 ===== -->
        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== 左侧面板：双路连接配置 ===== -->
            <Border Grid.Column="0" Style="{StaticResource CardStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <TextBlock Text="📡 连接配置" Style="{StaticResource TitleStyle}" Margin="0,0,0,14"/>

                        <!-- ===== 通道 1（COM1）===== -->
                        <Border Padding="10,8" Margin="0,0,0,12"
                                Background="#1A3A5C" CornerRadius="6"
                                BorderBrush="#2A4A7A" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="🔌 通道 1 — COM1" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#60A0FF" Margin="0,0,0,8"/>

                                <!-- IP -->
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Text="IP 地址" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding Ip1, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 端口 -->
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Text="TCP 端口" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding Port1, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 从站地址 -->
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="从站地址" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding SlaveAddr1, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 连接按钮 -->
                                <Button Content="{Binding Ch1ButtonText}"
                                        Command="{Binding ConnectCh1Command}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ch1Connected}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FFCC2936" Offset="0"/>
                                                                <GradientStop Color="#FFFF3535" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- ===== 通道 2（COM2）===== -->
                        <Border Padding="10,8" Margin="0,0,0,12"
                                Background="#1A3A2C" CornerRadius="6"
                                BorderBrush="#2A6A3A" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="🔌 通道 2 — COM2" FontSize="12" FontWeight="SemiBold"
                                           Foreground="#40C080" Margin="0,0,0,8"/>

                                <!-- IP -->
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Text="IP 地址" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding Ip2, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 端口 -->
                                <StackPanel Margin="0,0,0,6">
                                    <TextBlock Text="TCP 端口" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding Port2, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 从站地址 -->
                                <StackPanel Margin="0,0,0,8">
                                    <TextBlock Text="从站地址" Style="{StaticResource LabelStyle}"/>
                                    <TextBox Style="{StaticResource DarkTextBox}"
                                             Text="{Binding SlaveAddr2, UpdateSourceTrigger=PropertyChanged}"/>
                                </StackPanel>

                                <!-- 连接按钮 -->
                                <Button Content="{Binding Ch2ButtonText}"
                                        Command="{Binding ConnectCh2Command}"
                                        HorizontalAlignment="Stretch">
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Ch2Connected}" Value="True">
                                                    <Setter Property="Background">
                                                        <Setter.Value>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                                <GradientStop Color="#FF207050" Offset="0"/>
                                                                <GradientStop Color="#FF30C070" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </StackPanel>
                        </Border>

                        <!-- 一键连接两路 -->
                        <Button Content="⚡ 一键连接两路"
                                Command="{Binding ConnectAllCommand}"
                                HorizontalAlignment="Stretch"
                                Style="{StaticResource PrimaryButton}"
                                Margin="0,0,0,14"/>

                        <!-- 分隔线 -->
                        <Border Height="1" Background="{StaticResource CardBorderBrush}" Margin="0,0,0,10"/>

                        <!-- 协议说明 -->
                        <TextBlock TextWrapping="Wrap" FontSize="11" LineHeight="18"
                                   Foreground="{StaticResource TextMutedBrush}">
                            <Run Text="协议: Modbus RTU over TCP"/>
                            <LineBreak/>
                            <Run Text="功能码: 03(读) / 06(写)"/>
                            <LineBreak/>
                            <Run Text="寄存器: 40001 ~ 40013"/>
                            <LineBreak/>
                            <Run Text="两路独立 TCP，互不影响"/>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- ===== 右侧面板：设备仪表盘 ===== -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 设备 1 面板（COM1）-->
                    <views:DevicePanel Grid.Column="0" DataContext="{Binding Device1}"/>

                    <!-- 设备 2 面板（COM2）-->
                    <views:DevicePanel Grid.Column="1" DataContext="{Binding Device2}"/>
                </Grid>
            </ScrollViewer>
        </Grid>

        <!-- ===== 底部日志面板 ===== -->
        <Border Grid.Row="2" Style="{StaticResource CardStyle}" Margin="8,0,8,8" Padding="12,8">
            <Grid Height="120">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <TextBlock Text="📋 通信日志" Style="{StaticResource TitleStyle}" FontSize="13"
                               DockPanel.Dock="Left" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding LogEntries.Count, StringFormat='共 {0} 条'}"
                               DockPanel.Dock="Right" HorizontalAlignment="Right"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                               VerticalAlignment="Center"/>
                </DockPanel>

                <ListBox Grid.Row="1" Style="{StaticResource LogListBox}"
                         ItemsSource="{Binding LogEntries}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>
    </Grid>
</Window>
