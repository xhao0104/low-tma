<Window x:Class="ModbusMonitor.Views.PasswordDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="身份验证" Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        ResizeMode="NoResize"
        Background="{StaticResource PrimaryBgBrush}"
        BorderBrush="{StaticResource CardBorderBrush}"
        BorderThickness="1"
        MouseDown="Window_MouseDown">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Text="🔒 高级调试授权" FontSize="18" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}" Grid.Row="0" Margin="0,0,0,15"/>

        <!-- Message -->
        <TextBlock Text="请输入工程校验密码（888888）：" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Grid.Row="1" Margin="0,0,0,8"/>

        <!-- Password Input -->
        <PasswordBox x:Name="pwdBox" Grid.Row="2" Height="32" FontSize="14" Padding="8,4" Background="#16233B" Foreground="White" BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="1" KeyDown="pwdBox_KeyDown" Loaded="pwdBox_Loaded"/>

        <TextBlock x:Name="ErrorText" Text="密码错误" Foreground="#FF3535" FontSize="11" Grid.Row="3" Margin="0,5,0,0" Visibility="Collapsed"/>

        <!-- Buttons -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="取消" Width="70" Height="28" Margin="0,0,10,0" Click="Cancel_Click" Style="{StaticResource SmallButton}"/>
            <Button Content="验证" Width="70" Height="28" Click="Confirm_Click" Style="{StaticResource PrimaryButton}"/>
        </StackPanel>
    </Grid>
</Window>
