<Window x:Class="ModbusMonitor.Views.HistoryReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:oxy="http://oxyplot.org/wpf"
        xmlns:vm="clr-namespace:ModbusMonitor.ViewModels"
        Title="📊 历史趋势报告"
        Width="960" Height="640"
        MinWidth="700" MinHeight="450"
        Background="#FF0A0F16"
        WindowStartupLocation="CenterOwner">

    <Window.DataContext>
        <vm:HistoryReportViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Background" Value="#FF1A2A4A"/>
            <Setter Property="Foreground" Value="#FFCCDDEE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#FF2A3A6A"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FF2A3A6A"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource ToolButton}">
            <Setter Property="Background" Value="#FF0060A0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF0080D0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- 顶部工具栏 -->
            <RowDefinition Height="*"/>     <!-- 图表区 -->
            <RowDefinition Height="Auto"/>  <!-- 汇总条 -->
        </Grid.RowDefinitions>

        <!-- ===== 顶部工具栏 ===== -->
        <Border Grid.Row="0" Background="#FF101820" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <!-- 设备选择 -->
                <TextBlock Text="设备：" Foreground="#FF809ABB" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <ComboBox Width="200" Height="30" ItemsSource="{Binding DeviceKeys}"
                          SelectedItem="{Binding SelectedDeviceKey}"
                          Background="#FF1A2A4A" Foreground="#FFCCDDEE"
                          BorderBrush="#FF2A3A6A" FontSize="12"/>

                <Button Content="🔄 刷新" Command="{Binding RefreshCommand}"
                        Style="{StaticResource ToolButton}" Margin="12,0,0,0"/>
                <Button Content="📤 导出当前" Command="{Binding ExportDeviceCommand}"
                        Style="{StaticResource AccentButton}" Margin="8,0,0,0"/>
                <Button Content="📦 一键导出全部" Command="{Binding ExportAllCommand}"
                        Style="{StaticResource AccentButton}" Margin="8,0,0,0"/>
                <Button Content="🗑️ 清空当前数据" Command="{Binding ClearDeviceDataCommand}"
                        Margin="8,0,0,0" Padding="12,6" FontSize="12" Cursor="Hand"
                        Background="#FF3A1A1A" Foreground="#FFFF7070" BorderThickness="1" BorderBrush="#FF6A2A2A">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 右侧记录数 -->
                <TextBlock Margin="24,0,0,0" VerticalAlignment="Center" FontSize="11" Foreground="#FF557799"
                           Text="{Binding RecordCount, StringFormat='📋 共 {0} 条记录'}"/>
            </StackPanel>
        </Border>

        <!-- ===== OxyPlot 折线图 ===== -->
        <oxy:PlotView Grid.Row="1"
                      Model="{Binding PlotModel}"
                      Background="#FF0D1117"
                      Margin="8"/>

        <!-- ===== 底部汇总条 ===== -->
        <Border Grid.Row="2" Background="#FF101820" Padding="16,8">
            <TextBlock Text="{Binding SummaryText}"
                       FontSize="13" FontWeight="SemiBold"
                       Foreground="#FF00A8FF"
                       HorizontalAlignment="Center"/>
        </Border>
    </Grid>
</Window>
