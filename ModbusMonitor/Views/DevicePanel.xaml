<UserControl x:Class="ModbusMonitor.Views.DevicePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:ModbusMonitor.Converters">

    <UserControl.Resources>
        <converters:AlarmStatusToColorConverter x:Key="AlarmColorConv"/>
        <converters:FaultStatusToColorConverter x:Key="FaultColorConv"/>
        <converters:OnlineStatusToColorConverter x:Key="OnlineColorConv"/>
        <converters:TemperatureToColorConverter x:Key="TempColorConv"/>
    </UserControl.Resources>

    <Border Style="{StaticResource CardStyle}" MinWidth="380">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ===== 标题行 ===== -->
            <Border Grid.Row="0" Margin="0,0,0,12">
                <DockPanel>
                    <!-- 在线状态灯 -->
                    <Ellipse Style="{StaticResource LedIndicator}" DockPanel.Dock="Left"
                             Fill="{Binding Data.IsOnline, Converter={StaticResource OnlineColorConv}}"/>
                    <TextBlock Text="{Binding DeviceName}" Style="{StaticResource TitleStyle}" 
                               VerticalAlignment="Center"/>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                               Text="{Binding Data.LastUpdate, StringFormat='更新: {0:HH:mm:ss}'}"/>
                </DockPanel>
            </Border>

            <!-- ===== 温度大字号显示区 ===== -->
            <Border Grid.Row="1" Background="#FF0D1117" CornerRadius="8" Padding="20,16" Margin="0,0,0,12">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="实际温度" HorizontalAlignment="Center" 
                               Style="{StaticResource LabelStyle}" FontSize="13"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,4,0,0">
                        <TextBlock Text="{Binding Data.Temperature, StringFormat='{}{0:F1}'}" 
                                   FontSize="52" FontWeight="Bold" 
                                   Foreground="{Binding Data.Temperature, Converter={StaticResource TempColorConv}}"/>
                        <TextBlock Text="°C" FontSize="22" VerticalAlignment="Top" Margin="2,8,0,0"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 报警 / 故障状态行 ===== -->
            <Grid Grid.Row="2" Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 报警指示 -->
                <Border Grid.Column="0" Background="#FF0D1117" CornerRadius="6" Padding="12,10" Margin="0,0,4,0">
                    <StackPanel>
                        <TextBlock Text="报警指示" Style="{StaticResource LabelStyle}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Ellipse Style="{StaticResource LedIndicator}"
                                     Fill="{Binding Data.AlarmStatus, Converter={StaticResource AlarmColorConv}}"/>
                            <TextBlock Text="{Binding Data.AlarmStatusText}" Style="{StaticResource ValueStyle}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- 故障指示 -->
                <Border Grid.Column="1" Background="#FF0D1117" CornerRadius="6" Padding="12,10" Margin="4,0,0,0">
                    <StackPanel>
                        <TextBlock Text="故障指示" Style="{StaticResource LabelStyle}"/>
                        <DockPanel Margin="0,4,0,0">
                            <Ellipse Style="{StaticResource LedIndicator}"
                                     Fill="{Binding Data.FaultStatus, Converter={StaticResource FaultColorConv}}"/>
                            <TextBlock Text="{Binding Data.FaultStatusText}" Style="{StaticResource ValueStyle}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ===== 详细数据网格 ===== -->
            <Border Grid.Row="3" Background="#FF0D1117" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 运行时间 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                        <TextBlock Text="运行时间" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Data.RunTimeFormatted}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- 电池电压 -->
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="电池电压" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Style="{StaticResource ValueStyle}">
                            <Run Text="{Binding Data.BatteryVoltage, StringFormat='{}{0:F2}'}"/>
                            <Run Text="V" Foreground="{StaticResource TextSecondaryBrush}"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 从站地址 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                        <TextBlock Text="从站地址" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Data.SlaveAddress}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- 设备编号 -->
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="设备编号" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Data.DeviceNumber}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- 单片机 ID -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,8">
                        <TextBlock Text="单片机 ID" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Data.McuId, StringFormat='0x{0:X8}'}" Style="{StaticResource ValueStyle}" FontSize="12"/>
                    </StackPanel>

                    <!-- 波特率 -->
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="波特率" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Data.BaudRate}" Style="{StaticResource ValueStyle}"/>
                    </StackPanel>

                    <!-- 预警温度（当前值） -->
                    <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,8">
                        <TextBlock Text="预警温度" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Style="{StaticResource ValueStyle}">
                            <Run Text="{Binding Data.WarningTemperature}"/>
                            <Run Text="°C" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 报警温度（当前值） -->
                    <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                        <TextBlock Text="报警温度" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Style="{StaticResource ValueStyle}">
                            <Run Text="{Binding Data.AlarmTemperature}"/>
                            <Run Text="°C" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11"/>
                        </TextBlock>
                    </StackPanel>

                    <!-- 光感档位 -->
                    <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,0">
                        <TextBlock Text="光感档位" Style="{StaticResource LabelStyle}"/>
                        <TextBlock Text="{Binding Data.LightSensorLevel, StringFormat='档位 {0}'}" 
                                   Style="{StaticResource ValueStyle}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ===== 轮询统计卡片 ===== -->
            <Border Grid.Row="4" Background="#FF0D1117" CornerRadius="6" Padding="12,10" Margin="0,0,0,12">
                <StackPanel>
                    <!-- 标题行 + 重置按钮 -->
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="重置" Padding="8,2"
                                Command="{Binding ResetStatsCommand}"
                                Style="{StaticResource SmallButton}"/>
                        <TextBlock Text="📊 轮询统计" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- 节点活跃状态 -->
                    <DockPanel Margin="0,0,0,6">
                        <Ellipse DockPanel.Dock="Left" Margin="0,0,6,0" Width="10" Height="10">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#FF606060"/>
                                    <Style.Triggers>
                                        <!-- 有成功帧 → 绿色活跃 -->
                                        <DataTrigger Binding="{Binding HasRecentSuccess}" Value="True">
                                            <Setter Property="Fill" Value="#FF00E676"/>
                                        </DataTrigger>
                                        <!-- 超时但没有成功 → 橙色 -->
                                        <MultiDataTrigger>
                                            <MultiDataTrigger.Conditions>
                                                <Condition Binding="{Binding HasRecentSuccess}" Value="False"/>
                                                <Condition Binding="{Binding Data.IsOnline}" Value="True"/>
                                            </MultiDataTrigger.Conditions>
                                            <Setter Property="Fill" Value="#FFFFB300"/>
                                        </MultiDataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontSize="12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="节点待唤醒"/>
                                    <Setter Property="Foreground" Value="#FFFFB300"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasRecentSuccess}" Value="True">
                                            <Setter Property="Text" Value="节点活跃（5秒内有成功帧）"/>
                                            <Setter Property="Foreground" Value="#FF00E676"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>

                    <!-- 成功/超时/异常 计数 -->
                    <TextBlock Text="{Binding PollSummaryText}" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4"/>

                    <!-- 最近成功时间 -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="最近成功：" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}"/>
                        <TextBlock Text="{Binding LastSuccessTimeText}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ===== 参数设置区 ===== -->
            <Border Grid.Row="5" Background="#FF0D1117" CornerRadius="6" Padding="12,10">
                <StackPanel>
                    <TextBlock Text="参数设置" Style="{StaticResource TitleStyle}" FontSize="14" Margin="0,0,0,10"/>

                    <!-- 预警温度写入 -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="写入" 
                                Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                Command="{Binding WriteWarningTempCommand}"/>
                        <StackPanel>
                            <TextBlock Text="预警温度 (°C)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding InputWarningTemp, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- 报警温度写入 -->
                    <DockPanel Margin="0,0,0,6">
                        <Button DockPanel.Dock="Right" Content="写入" 
                                Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                Command="{Binding WriteAlarmTempCommand}"/>
                        <StackPanel>
                            <TextBlock Text="报警温度 (°C)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding InputAlarmTemp, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- 光感档位写入 -->
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="写入" 
                                Style="{StaticResource SmallButton}" Margin="6,0,0,0"
                                Command="{Binding WriteLightLevelCommand}"/>
                        <StackPanel>
                            <TextBlock Text="光感档位 (1/2/3)" Style="{StaticResource LabelStyle}"/>
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding InputLightLevel, UpdateSourceTrigger=PropertyChanged}"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- 一键写入 -->
                    <Button Content="📤 一键写入所有参数" Style="{StaticResource SuccessButton}"
                            Command="{Binding WriteAllParamsCommand}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
